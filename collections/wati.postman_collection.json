  "info": {
    "_postman_id": "674caf46-f940-47ba-8215-b570a838913c",
    "name": "WATI WhatsApp Business API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Tenant-scoped REST API for the WATI WhatsApp Business platform. Use this API\nto send WhatsApp template and session messages, manage contacts, fetch\nconversation history, and orchestrate operator assignments. Each WATI\nworkspace exposes its own base URL (for example,\n`https://live-mt-server.wati.io/{tenantId}`) and authenticates calls with a\nBearer access token issued from the WATI dashboard.\n\n\nContact Support:\n Name: WATI Support",
      "type": "text/plain"
    }
  }
